/// =====================================================
/// MEDIA
/// =====================================================
/// Generic reusable media asset entity.
///
/// This model centralizes all media files
/// across the platform.
///
/// Used for:
/// - event galleries
/// - athlete photos
/// - provider portfolios
/// - banners
/// - route maps
/// - branding
/// - videos
///
/// IMPORTANT:
/// This architecture is intentionally reusable and scalable.
/// =====================================================

model Media {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// Public file URL.
  ///
  /// Usually stored in:
  /// - S3
  /// - Cloudinary
  /// - Supabase Storage
  /// - CDN providers
  url String @unique

  /// Media asset type.
  type MediaType

  /// Alternative text for SEO and accessibility.
  altText String? @map("alt_text")

  /// Media width in pixels.
  width Int?

  /// Media height in pixels.
  height Int?

  /// External storage provider.
  ///
  /// Examples:
  /// - s3
  /// - cloudinary
  /// - supabase
  provider String?

  /// Service provider gallery relations.
  serviceProviderMedia ServiceProviderMedia[]

  /// Event series gallery relations.
  eventSeriesMedia EventSeriesMedia[]

  /// Event edition gallery relations.
  eventEditionMedia EventEditionMedia[]

  /// Athlete gallery relations.
  athleteMedia AthleteMedia[]

  /// Organizer gallery relations.
  organizerMedia OrganizerMedia[]

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  @@index([type])
  @@map("media")
}

/// =====================================================
/// SERVICE PROVIDER MEDIA
/// =====================================================
/// Links media assets to service providers.
///
/// Used for:
/// - photographer portfolios
/// - coach branding
/// - club galleries
/// - physiotherapist facilities
/// - promotional content
///
/// Enables scalable provider galleries.
/// =====================================================

model ServiceProviderMedia {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// Service provider reference.
  providerId String @map("provider_id") @db.Uuid

  /// Media asset reference.
  mediaId String @map("media_id") @db.Uuid

  /// Context of media usage.
  type MediaUsageType @default(GALLERY)

  /// Optional public caption.
  caption String?

  /// Display order inside galleries.
  ///
  /// Useful for:
  /// - featured images
  /// - portfolio ordering
  sortOrder Int? @map("sort_order")

  /// Provider relation.
  provider ServiceProvider @relation(fields: [providerId], references: [id])

  /// Media relation.
  media Media @relation(fields: [mediaId], references: [id])

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  /// Prevent duplicated media assignments.
  @@unique([providerId, mediaId])
  /// Fast provider gallery lookup.
  @@index([providerId])
  /// Media usage filtering.
  @@index([type])
  /// Gallery ordering optimization.
  @@index([providerId, sortOrder])
  @@map("service_provider_media")
}

