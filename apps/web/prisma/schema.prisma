/// =====================================================
/// TAG
/// =====================================================
/// Flexible tagging system used across the platform.
///
/// Tags improve:
/// - search
/// - discovery
/// - filtering
/// - SEO
/// - recommendations
///
/// Examples:
/// - trail-running
/// - mountain
/// - beginner-friendly
/// - ultra-distance
/// - official-photography
/// =====================================================

model Tag {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// Public tag name.
  ///
  /// Example:
  /// Trail Running
  name String

  /// SEO-friendly unique slug.
  ///
  /// Example:
  /// trail-running
  slug String @unique

  /// Optional category grouping.
  ///
  /// Examples:
  /// - terrain
  /// - audience
  /// - service
  /// - event_type
  category String?

  /// Event associations.
  eventSeries EventSeriesTag[]

  /// Service provider associations.
  providers ServiceProviderTag[]

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  @@index([slug])
  @@index([category])
  @@map("tags")
}

/// =====================================================
/// EVENT SERIES TAG
/// =====================================================
/// Junction table linking tags to event series.
///
/// Enables:
/// - event filtering
/// - SEO categorization
/// - recommendations
/// =====================================================

model EventSeriesTag {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// Event series reference.
  eventSeriesId String @map("event_series_id") @db.Uuid

  /// Tag reference.
  tagId String @map("tag_id") @db.Uuid

  /// Event relation.
  eventSeries EventSeries @relation(fields: [eventSeriesId], references: [id])

  /// Tag relation.
  tag Tag @relation(fields: [tagId], references: [id])

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  /// Prevent duplicated tag assignments.
  @@unique([eventSeriesId, tagId])
  @@index([tagId])
  @@map("event_series_tags")
}

/// =====================================================
/// SERVICE PROVIDER TAG
/// =====================================================
/// Junction table linking tags to service providers.
///
/// Enables:
/// - marketplace discovery
/// - provider filtering
/// - recommendation systems
/// - SEO grouping
/// =====================================================

model ServiceProviderTag {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// Service provider reference.
  providerId String @map("provider_id") @db.Uuid

