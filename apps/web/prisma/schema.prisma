model User {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// User email address.
  ///
  /// Nullable for future OAuth flexibility.
  email String? @unique

  /// Public display name.
  name String?

  /// User favorites.
  favorites Favorite[]

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}

/// =====================================================
/// FAVORITE
/// =====================================================
/// Generic favorites system.
///
/// Allows users to save entities across the platform.
///
/// Examples:
/// - events
/// - athletes
/// - providers
///
/// IMPORTANT:
/// This uses a polymorphic structure intentionally
/// to avoid creating separate favorite tables.
/// =====================================================

model Favorite {
  /// Primary UUID identifier.
  id String @id @default(uuid()) @db.Uuid

  /// User reference.
  userId String @map("user_id") @db.Uuid

  /// Type of entity being favorited.
  entityType FavoriteEntityType @map("entity_type")

  /// Target entity UUID.
  ///
  /// Represents:
  /// - EventSeries.id
  /// - Athlete.id
  /// - ServiceProvider.id
  entityId String @map("entity_id") @db.Uuid

  /// User relation.
  user User @relation(fields: [userId], references: [id])

  /// Record creation timestamp.
  createdAt DateTime @default(now()) @map("created_at")

  /// Record last update timestamp.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft delete timestamp.
  deletedAt DateTime? @map("deleted_at")

  /// Prevent duplicated favorites.
  @@unique([userId, entityType, entityId])
  @@index([userId])
  /// Fast favorite lookup optimization.
  @@index([entityType, entityId])
  @@map("favorites")
}

